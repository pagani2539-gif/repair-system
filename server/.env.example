NODE_ENV=production
PORT=5221
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Leave blank for same-origin production use.
# Use a comma-separated list only when browsers access the API from another origin.
CORS_ORIGIN=

# Set to 1 only when you need to temporarily disable startup and scheduled backups.
DISABLE_BACKUP_SCHEDULER=0

# Initial administrator account, seeded only when the users table is empty
# (first boot). If SEED_ADMIN_PASSWORD is left blank a random one-time password
# is generated and printed ONCE to the server log — capture it from there.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
